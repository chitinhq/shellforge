# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

# Context window (tokens) — keep low for memory efficiency
OLLAMA_CTX_SIZE=4096

# Agent defaults
AGENT_TIMEOUT=300
AGENT_OUTPUT_DIR=outputs

# AgentGuard (optional cloud telemetry)
# AGENTGUARD_API_KEY=
# AGENTGUARD_TELEMETRY_URL=

# Memory optimization (future)
# MEMORY_BACKEND=google-a2a
# MEMORY_MAX_MB=512
