{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@config/*": ["config/*"],
      "@adapters/*": ["adapters/*"]
    }
  },
  "include": ["agents/**/*.ts", "config/**/*.ts", "adapters/**/*.ts"],
  "exclude": ["node_modules", "dist", "outputs"]
}
